<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Aplazo — Registration Flow Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;800&display=swap" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
<style>
:root{
  --cyan:#4AC9E3;--teal:#214345;--foam:#D6F5FA;--sea:#0C617A;
  --red:#D41413;--red-l:#FDEAEA;--yellow:#B07800;--yellow-l:#FFF3CC;
  --green:#5AAD12;--green-l:#EAF7D5;--orange:#E07000;--orange-l:#FFF0D9;
  --bg:#F2F4F6;--surf:#EBEDF0;--card:#fff;
  --t1:#060606;--t2:#2E343A;--t3:#7F8D98;--br:#E2E5E8;
  --sh:0 1px 4px rgba(0,0,0,.08),0 1px 2px rgba(0,0,0,.04);
  --sh-md:0 4px 16px rgba(0,0,0,.10),0 2px 6px rgba(0,0,0,.06);
  --font:'Manrope',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;font-family:var(--font);}
body{background:var(--bg);}
nav{background:var(--teal);height:56px;display:flex;align-items:center;padding:0 24px;gap:12px;position:sticky;top:0;z-index:50;box-shadow:var(--sh-md);}
nav .sep{width:1px;height:20px;background:rgba(255,255,255,.2);}
nav .sub{font-size:12px;color:rgba(255,255,255,.5);}
nav .ts{margin-left:auto;font-size:11px;color:rgba(255,255,255,.4);}
nav .ts b{color:var(--cyan);}
.dot{width:7px;height:7px;border-radius:50%;background:var(--cyan);display:inline-block;margin-right:4px;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
main{max-width:1200px;margin:0 auto;padding:28px 20px 48px;}

/* LOADING / ERROR */
#loading-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 0;gap:14px;}
.spinner{width:36px;height:36px;border:3px solid var(--br);border-top-color:var(--cyan);border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}
#loading-state p{font-size:14px;color:var(--t3);}
#error-state{display:none;background:var(--red-l);border:1px solid var(--red);border-radius:12px;padding:16px 20px;color:var(--red);font-size:13px;margin:32px 0;}
#dashboard{display:none;}

.note-bar{background:#FFF3CC;border:1px solid #B07800;border-radius:12px;padding:10px 16px;font-size:12px;color:#7A5200;display:flex;align-items:center;gap:8px;margin-bottom:20px;}
.divider{height:1px;background:var(--br);margin:20px 0;}

/* SEGMENT CARDS */
.seg-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;}
.seg-card{background:var(--card);border:1px solid var(--br);border-radius:16px;overflow:hidden;box-shadow:var(--sh);}
.seg-head{display:flex;align-items:center;justify-content:space-between;padding:10px 16px;border-bottom:1px solid var(--br);}
.scount{font-size:11px;color:var(--t3);}
.badge-oc{background:var(--foam);color:var(--sea);padding:3px 10px;border-radius:100px;font-size:11px;font-weight:700;}
.badge-std{background:rgba(33,67,69,.1);color:var(--teal);padding:3px 10px;border-radius:100px;font-size:11px;font-weight:700;}
.metrics-row{display:grid;grid-template-columns:repeat(3,1fr);}
.metric{padding:12px 14px;border-right:1px solid var(--br);}
.metric:last-child{border-right:none;}
.ml{font-size:10px;font-weight:800;color:var(--t3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:5px;}
.mv{font-size:20px;font-weight:800;color:var(--t1);line-height:1.1;}
.ms{font-size:10px;color:var(--t3);margin-top:2px;}

/* DQ LARGE */
.dq-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:6px;}
.dq-box{background:var(--card);border:1px solid var(--br);border-radius:16px;padding:16px 20px;display:flex;align-items:center;gap:16px;box-shadow:var(--sh);}
.dq-icon{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.dq-box.oc .dq-icon{background:var(--foam);color:var(--sea);}
.dq-box.std .dq-icon{background:rgba(33,67,69,.08);color:var(--teal);}
.dq-lbl{font-size:11px;font-weight:600;color:var(--t2);margin-bottom:4px;}
.dq-val{font-size:36px;font-weight:800;line-height:1;}
.dq-box.oc .dq-val{color:var(--sea);}
.dq-box.std .dq-val{color:var(--red);}
.dq-sub{font-size:11px;color:var(--t3);margin-top:3px;}
.dq-note{font-size:11px;color:var(--t3);text-align:center;margin-top:8px;margin-bottom:4px;}
.dq-note b{color:var(--red);}

/* MONTH SECTION */
.month-section{background:var(--card);border:1px solid var(--br);border-radius:16px;overflow:hidden;box-shadow:var(--sh);margin-bottom:24px;}
.month-header{padding:14px 18px;border-bottom:1px solid var(--br);}
.month-header h3{font-size:13px;font-weight:800;color:var(--t2);}
.month-header p{font-size:11px;color:var(--t3);margin-top:2px;}
.month-tabs{display:flex;gap:6px;flex-wrap:wrap;padding:14px 18px;border-bottom:1px solid var(--br);}
.mtab{font-size:12px;font-weight:600;padding:5px 14px;border-radius:100px;border:1px solid var(--br);background:var(--surf);color:var(--t2);cursor:pointer;transition:all .15s;}
.mtab:hover{border-color:var(--cyan);}
.mtab.active{background:var(--teal);color:#fff;border-color:var(--teal);}
.month-stats{display:grid;grid-template-columns:repeat(4,1fr);border-bottom:1px solid var(--br);}
.mstat{padding:12px 16px;border-right:1px solid var(--br);}
.mstat:last-child{border-right:none;}
.msl{font-size:10px;font-weight:800;color:var(--t3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:5px;}
.msv{font-size:18px;font-weight:800;color:var(--t1);}
.mss{font-size:10px;color:var(--t3);margin-top:2px;}
.month-merchants{padding:14px 18px;}
.mm-title{font-size:11px;font-weight:800;color:var(--t3);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;}
.mm-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px;}
.mm-chip{background:var(--surf);border:1px solid var(--br);border-radius:10px;padding:8px 12px;}
.mc-name{font-weight:700;color:var(--t1);font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.mc-id{font-size:10px;color:var(--t3);margin-top:1px;}
.mc-seg{font-size:10px;font-weight:600;margin-top:3px;}
.mc-oc{color:var(--sea);}
.mc-std{color:var(--teal);}

/* GMV AT RISK SUMMARY */
.top-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:24px;}
.stat-card{background:var(--card);border:1px solid var(--br);border-radius:14px;padding:16px 18px;box-shadow:var(--sh);}
.slbl{font-size:10px;font-weight:800;color:var(--t3);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;display:flex;align-items:center;gap:5px;}
.sval{font-size:22px;font-weight:800;}
.ssub{font-size:11px;color:var(--t3);margin-top:3px;}

/* FILTER BAR */
.fbar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:12px;padding:12px 16px;background:var(--card);border:1px solid var(--br);border-radius:14px;box-shadow:var(--sh);}
.fbar label{font-size:10px;font-weight:800;color:var(--t3);text-transform:uppercase;letter-spacing:1.2px;white-space:nowrap;}
.fbar input,.fbar select{font-size:12px;height:32px;border-radius:10px;border:1px solid var(--br);background:var(--card);color:var(--t2);padding:0 10px;outline:none;font-family:var(--font);}
.fbar input{min-width:160px;flex:1;}
.fbar input:focus,.fbar select:focus{border-color:var(--cyan);box-shadow:0 0 0 2px rgba(74,201,227,.15);}
.sort-btn{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:700;padding:4px 10px;border-radius:10px;border:1px solid var(--br);background:var(--surf);color:var(--t3);cursor:pointer;white-space:nowrap;font-family:var(--font);}
.sort-btn.active{background:var(--card);border-color:var(--t2);color:var(--t1);}
.fcount{margin-left:auto;font-size:11px;color:var(--t3);}

/* TABLE */
.tcard{background:var(--card);border:1px solid var(--br);border-radius:16px;overflow:hidden;box-shadow:var(--sh);}
.thead-info{padding:14px 18px;border-bottom:1px solid var(--br);}
.thead-info h3{font-size:13px;font-weight:800;color:var(--t2);}
.thead-info p{font-size:11px;color:var(--t3);margin-top:2px;}
table{width:100%;border-collapse:collapse;table-layout:fixed;}
thead th{padding:9px 12px;text-align:left;font-size:10px;font-weight:800;color:var(--t3);text-transform:uppercase;letter-spacing:.8px;background:var(--surf);border-bottom:1px solid var(--br);white-space:nowrap;cursor:pointer;user-select:none;}
thead th:hover{color:var(--t2);}
thead th.sorted{color:var(--t1);}
tbody tr.dr{border-bottom:1px solid var(--br);cursor:pointer;transition:background .1s;}
tbody tr.dr:hover{background:rgba(74,201,227,.04);}
tbody tr.dr.hi{background:rgba(212,20,19,.025);}
tbody td{padding:9px 12px;color:var(--t2);font-weight:500;vertical-align:middle;overflow:hidden;text-overflow:ellipsis;}
tbody td b{color:var(--t1);font-weight:800;}
.mname{font-weight:700;color:var(--t1);font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.mid{font-size:10px;color:var(--t3);}
.seg-oc{background:var(--foam);color:var(--sea);display:inline-flex;padding:2px 7px;border-radius:100px;font-size:10px;font-weight:700;}
.seg-std{background:rgba(33,67,69,.1);color:var(--teal);display:inline-flex;padding:2px 7px;border-radius:100px;font-size:10px;font-weight:700;}
.rbadge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:100px;font-size:11px;font-weight:700;}
.r-HIGH{background:var(--red-l);color:var(--red);}
.r-MEDIUM{background:var(--yellow-l);color:var(--yellow);}
.r-LOW{background:var(--green-l);color:var(--green);}
.r-PENDING{background:var(--surf);color:var(--t3);}
.bar-wrap{display:flex;align-items:center;gap:7px;}
.bar-bg{flex:1;height:5px;background:var(--surf);border-radius:100px;overflow:hidden;min-width:50px;}
.bar-fill{height:100%;border-radius:100px;}
.bar-val{font-size:11px;font-weight:700;white-space:nowrap;}
.xrow td{padding:0;background:rgba(248,252,253,.9);border-bottom:1px solid var(--br);}
.xinner{padding:14px 18px;}
.xtitle{font-size:12px;font-weight:800;color:var(--t1);margin-bottom:10px;display:flex;align-items:center;gap:6px;}
.xgrid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:8px;margin-bottom:10px;}
.xstat{background:var(--surf);border-radius:10px;padding:8px 12px;}
.xl{font-size:10px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.7px;margin-bottom:3px;}
.xv{font-size:14px;font-weight:800;color:var(--t1);}
.xv.danger{color:var(--red);}
.xv.warn{color:var(--yellow);}
.verdict{border-radius:10px;padding:11px 14px;font-size:12px;font-weight:600;line-height:1.65;border-left:3px solid;}
.v-high{background:var(--red-l);color:#8B0000;border-color:var(--red);}
.v-med{background:var(--yellow-l);color:#5A3E00;border-color:var(--yellow);}
.v-low{background:var(--green-l);color:#2A5500;border-color:var(--green);}
.v-pending{background:var(--surf);color:var(--t3);border-color:var(--br);}
</style>
</head>
<body>

<nav>
  <svg width="120" height="30" viewBox="0 0 160 40" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g clip-path="url(#lc)">
      <path d="M139.603 0H20.3966C9.13185 0 0 8.95338 0 19.9979V20.0021C0 31.0466 9.13185 40 20.3966 40H139.603C150.868 40 160 31.0466 160 20.0021V19.9979C160 8.95338 150.868 0 139.603 0Z" fill="#7FEDFA"/>
