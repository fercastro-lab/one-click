    <defs><clipPath id="lc"><rect width="160" height="40" fill="white"/></clipPath></defs>
  </svg>
  <div class="sep"></div>
  <span class="sub">Registration Flow Dashboard</span>
  <span class="ts"><span class="dot"></span><b id="nav-updated">Loading...</b></span>
</nav>

<main>
  <div id="loading-state">
    <div class="spinner"></div>
    <p>Loading live data...</p>
  </div>
  <div id="error-state"></div>
  <div id="dashboard">

    <div class="note-bar">
      <i class="bi bi-info-circle-fill"></i>
      <span><b>DQ note:</b> DOB22 has a 22-day natural delay — merchants activated after ~Apr 27 show "—". Click any merchant row to expand full fraud analysis.</span>
    </div>

    <!-- SEGMENT CARDS -->
    <div class="seg-grid">
      <div class="seg-card">
        <div class="seg-head">
          <span class="badge-oc"><i class="bi bi-lightning-charge-fill"></i> One-Click</span>
          <span class="scount" id="oc-count">— merchants</span>
        </div>
        <div class="metrics-row">
          <div class="metric"><div class="ml">GMV</div><div class="mv" id="oc-gmv">—</div><div class="ms">MXN total</div></div>
          <div class="metric"><div class="ml">Loans</div><div class="mv" id="oc-loans">—</div><div class="ms">originated</div></div>
          <div class="metric"><div class="ml">AOV</div><div class="mv" id="oc-aov">—</div><div class="ms">avg. ticket</div></div>
        </div>
      </div>
      <div class="seg-card">
        <div class="seg-head">
          <span class="badge-std"><i class="bi bi-person-check-fill"></i> Standard</span>
          <span class="scount" id="std-count">— merchants</span>
        </div>
        <div class="metrics-row">
          <div class="metric"><div class="ml">GMV</div><div class="mv" id="std-gmv">—</div><div class="ms">MXN total</div></div>
          <div class="metric"><div class="ml">Loans</div><div class="mv" id="std-loans">—</div><div class="ms">originated</div></div>
          <div class="metric"><div class="ml">AOV</div><div class="mv" id="std-aov">—</div><div class="ms">avg. ticket</div></div>
        </div>
      </div>
    </div>

    <!-- DQ LARGE -->
    <div class="dq-grid">
      <div class="dq-box oc">
        <div class="dq-icon"><i class="bi bi-lightning-charge-fill"></i></div>
        <div>
          <div class="dq-lbl">One-Click · DQ DOB22</div>
          <div class="dq-val" id="oc-dq">—</div>
          <div class="dq-sub">mature loans only · ≥22 days old</div>
        </div>
      </div>
      <div class="dq-box std">
        <div class="dq-icon"><i class="bi bi-person-check-fill"></i></div>
        <div>
          <div class="dq-lbl">Standard · DQ DOB22</div>
          <div class="dq-val" id="std-dq">—</div>
          <div class="dq-sub">mature loans only · ≥22 days old</div>
        </div>
      </div>
    </div>
    <div class="dq-note" id="dq-diff-note">Calculating...</div>

    <div class="divider"></div>

    <!-- ACTIVATIONS BY MONTH -->
    <div class="month-section">
      <div class="month-header">
        <h3>Merchant activations by month</h3>
        <p>GMV by registration flow per month · click a month to filter the table below</p>
      </div>
      <div class="month-tabs" id="month-tabs"></div>
      <div class="month-stats" id="month-stats"></div>
      <div class="month-merchants" id="month-merchants"></div>
    </div>

    <!-- GMV AT RISK SUMMARY -->
    <div class="top-stats">
      <div class="stat-card">
        <div class="slbl"><i class="bi bi-exclamation-triangle" style="color:var(--red)"></i> Confirmed GMV at risk</div>
        <div class="sval" id="stat-confirmed" style="color:var(--red);">—</div>
        <div class="ssub" id="stat-confirmed-sub">merchants with mature DQ</div>
      </div>
      <div class="stat-card">
        <div class="slbl"><i class="bi bi-clock-history" style="color:var(--yellow)"></i> Pending exposure</div>
        <div class="sval" id="stat-pending" style="color:var(--yellow);">—</div>
        <div class="ssub">GMV from merchants &lt;22 days old</div>
      </div>
      <div class="stat-card">
        <div class="slbl"><i class="bi bi-graph-up"></i> Total GMV · all merchants</div>
        <div class="sval" id="stat-total">—</div>
        <div class="ssub" id="stat-total-sub">all merchants</div>
      </div>
    </div>

    <!-- FILTER BAR -->
    <div class="fbar">
      <label><i class="bi bi-search"></i></label>
      <input type="text" id="q" placeholder="Search by name or ID..." oninput="renderTable()"/>
      <label>Seg</label>
      <select id="f-seg" onchange="renderTable()">
        <option value="all">All</option>
        <option value="one_click">One-Click</option>
        <option value="standard">Standard</option>
      </select>
      <label>Show</label>
      <select id="f-show" onchange="renderTable()">
        <option value="all">All merchants</option>
        <option value="risk">With DQ signal</option>
        <option value="pending">DQ pending</option>
      </select>
      <label>Sort</label>
      <button class="sort-btn active" id="btn-risk"  onclick="setSort('risk',this)">GMV at risk <i id="icon-risk" class="bi bi-sort-down"></i></button>
      <button class="sort-btn"        id="btn-gmv"   onclick="setSort('gmv',this)">Total GMV <i id="icon-gmv" class="bi bi-arrow-down-up"></i></button>
      <button class="sort-btn"        id="btn-dq"    onclick="setSort('dq',this)">DQ% <i id="icon-dq" class="bi bi-arrow-down-up"></i></button>
      <button class="sort-btn"        id="btn-loans" onclick="setSort('loans',this)">Loans <i id="icon-loans" class="bi bi-arrow-down-up"></i></button>
      <span class="fcount" id="fcount"></span>
    </div>

    <div class="tcard">
      <div class="thead-info">
        <h3>All merchants with activity — sorted by GMV at risk</h3>
        <p>GMV at risk = Total GMV × DQ rate · click column headers to sort · click any row to expand fraud analysis</p>
      </div>
      <div style="overflow-x:auto">
        <table>
          <colgroup>
            <col style="width:165px"/><col style="width:82px"/><col style="width:92px"/>
            <col style="width:68px"/><col style="width:172px"/><col style="width:52px"/>
            <col style="width:56px"/><col style="width:82px"/><col style="width:52px"/>
            <col style="width:92px"/>
          </colgroup>
          <thead><tr>
            <th onclick="setSort('name',null)">Merchant <i class="bi bi-arrow-down-up" id="th-icon-name" style="font-size:10px;opacity:.4"></i></th>
            <th>Seg</th>
            <th onclick="setSort('gmv',null)"   id="th-gmv">Total GMV <i class="bi bi-arrow-down-up" id="th-icon-gmv" style="font-size:10px;opacity:.4"></i></th>
            <th onclick="setSort('dq',null)"    id="th-dq">DQ <i class="bi bi-arrow-down-up" id="th-icon-dq" style="font-size:10px;opacity:.4"></i></th>
            <th onclick="setSort('risk',null)"  id="th-risk" class="sorted">GMV at risk <i class="bi bi-sort-down" id="th-icon-risk" style="font-size:10px;opacity:1"></i></th>
            <th onclick="setSort('loans',null)" id="th-loans">Loans <i class="bi bi-arrow-down-up" id="th-icon-loans" style="font-size:10px;opacity:.4"></i></th>
            <th>Cust.</th>
            <th>Avg ticket</th>
            <th>% new</th>
            <th>Priority</th>
          </tr></thead>
          <tbody id="tbody"></tbody>
        </table>
      </div>
    </div>

  </div><!-- end #dashboard -->
</main>

<script>
// ============================================================
// CONFIG — paste your Sheets CSV URL here after publishing
// ============================================================
var SHEET_CSV_URL = "https://docs.google.com/spreadsheets/d/17Xw6qpviVfbUbdtSVf5Pw22xYOL8526omLNW-wRbtMw/gviz/tq?tqx=out:csv&range=A1";

// ============================================================
// STATE
// ============================================================
var DATA = [];
var EXP  = {};
var SORT = 'risk';
var SORT_DIRS = {risk:false,gmv:false,dq:false,loans:false,name:true};
var ACTIVE_MONTH = 'all';
var MAX_RISK = 1;
var MONTH_LABELS = {
  '2026-04':'April 2026','2026-05':'May 2026','2026-06':'June 2026',
  '2026-07':'July 2026','2026-08':'August 2026','2026-09':'September 2026',
  '2026-10':'October 2026','2026-11':'November 2026','2026-12':'December 2026',
  '2025-12':'December 2025','2025-11':'November 2025'
};

// ============================================================
// LOAD DATA FROM GOOGLE SHEETS
// ============================================================
function loadData() {
  var url = "https://script.google.com/macros/s/AKfycbzDLr4WpQoxJC5sXtje1ROVEphTBQaMNbL840nPPlzmIjeNumquJy8x0eaiHqcTleYc/exec";
  fetch(url)
    .then(function(r) {
      return r.text();
    })
    .then(function(text) {
      var payload;
      try {
        payload = JSON.parse(text);
      } catch(e) {
        showError("JSON parse failed.<br><b>Raw response:</b><br><pre style='font-size:10px;margin-top:6px;white-space:pre-wrap;word-break:break-all;'>" + text.substring(0, 500) + "</pre>");
        return;
      }
      initDashboard(payload);
    })
    .catch(function(err) {
      // fetch itself failed — likely CORS. Fall back to JSONP.
      window._dashboardCallback = function(payload) { initDashboard(payload); };
      var script = document.createElement('script');
      script.src = url + "?callback=_dashboardCallback";
      script.onerror = function() {
        showError("Could not load data. Both fetch and JSONP failed.<br>Check that the Apps Script Web App is deployed with access: <b>Anyone</b>.");
      };
      document.head.appendChild(script);
      setTimeout(function() {
        if (document.getElementById('loading-state').style.display !== 'none') {
          showError("Request timed out after 10s.<br>Check Apps Script deployment and run syncDashboard first.");
        }
      }, 10000);
    });
}

function showError(msg) {
  document.getElementById('loading-state').style.display = 'none';
  var el = document.getElementById('error-state');
  el.style.display = 'block';
  el.innerHTML = '<i class="bi bi-exclamation-triangle-fill"></i> ' + msg;
}

// ============================================================
// INIT — called once data loads
// ============================================================
function initDashboard(payload) {
  document.getElementById('loading-state').style.display = 'none';
  document.getElementById('dashboard').style.display = 'block';
  try {
  var d = new Date(payload.updated_at);
  document.getElementById('nav-updated').textContent = 'Updated ' + d.toLocaleDateString('en-US', {month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});

  var oc  = payload.one_click  || {};
  var std = payload.standard   || {};
  DATA    = payload.fraud_flags || [];
  var segs = payload.segments  || {oneClick:[],standard:[]};

  // Segment cards
  var ocCount  = (segs.oneClick  || []).length;
  var stdCount = (segs.standard  || []).length;
  var ocActive  = DATA.filter(function(r){return r.segment==='one_click';}).length;
  var stdActive = DATA.filter(function(r){return r.segment==='standard';}).length;

  document.getElementById('oc-count').textContent  = ocCount  + ' merchants · ' + ocActive  + ' with activity';
  document.getElementById('std-count').textContent = stdCount + ' merchants · ' + stdActive + ' with activity';
  document.getElementById('oc-gmv').textContent    = mxn(oc.gmv);
  document.getElementById('oc-loans').textContent  = (oc.loans||0).toLocaleString('en-US');
  document.getElementById('oc-aov').textContent    = mxn(oc.aov);
  document.getElementById('std-gmv').textContent   = mxn(std.gmv);
  document.getElementById('std-loans').textContent = (std.loans||0).toLocaleString('en-US');
  document.getElementById('std-aov').textContent   = mxn(std.aov);

  // DQ
  var dqOC  = oc.dq_rate_dob22  != null ? (oc.dq_rate_dob22  * 100).toFixed(1) + '%' : '—';
  var dqSTD = std.dq_rate_dob22 != null ? (std.dq_rate_dob22 * 100).toFixed(1) + '%' : '—';
  document.getElementById('oc-dq').textContent  = dqOC;
  document.getElementById('std-dq').textContent = dqSTD;
  if (oc.dq_rate_dob22 != null && std.dq_rate_dob22 != null) {
    var diff = Math.abs((std.dq_rate_dob22 - oc.dq_rate_dob22) * 100).toFixed(1);
    var higher = std.dq_rate_dob22 >= oc.dq_rate_dob22 ? 'Standard' : 'One-Click';
    document.getElementById('dq-diff-note').innerHTML = higher + ' has <b>+' + diff + 'pp</b> higher delinquency — DQ will stabilize as cohort matures.';
  }

  // GMV at risk summary
  var confirmed = 0, pending = 0, total = 0, confirmedCount = 0;
  DATA.forEach(function(r) {
    total += (r.total_gmv || 0);
    if (r.gmv_at_risk != null) { confirmed += (r.gmv_at_risk || 0); confirmedCount++; }
    else pending += (r.total_gmv || 0);
  });
  MAX_RISK = Math.max(confirmed, 1);
  document.getElementById('stat-confirmed').textContent     = mxn(confirmed) + ' MXN';
  document.getElementById('stat-confirmed-sub').textContent = confirmedCount + ' merchants with mature DQ';
  document.getElementById('stat-pending').textContent       = mxn(pending) + ' MXN';
  document.getElementById('stat-total').textContent         = mxn(total) + ' MXN';
  document.getElementById('stat-total-sub').textContent     = DATA.length + ' merchants · One-Click + Standard';

  // Build month section using HubSpot activation dates
  buildMonthSection(segs, DATA);

  renderTable();
  } catch(e) {
    showError("Error rendering dashboard: " + e.message + "<br><pre style='font-size:10px;margin-top:8px;'>" + e.stack + "</pre>");
  }
}

// ============================================================
// MONTH SECTION
// ============================================================
function getMonth(d) { return d ? d.substring(0,7) : ''; }

function buildMonthSection(segs, merchants) {
  var months = {};

  // Use HubSpot deal dates for activation month
  var allSegs = (segs.oneClick||[]).concat(segs.standard||[]);
  allSegs.forEach(function(s) {
    var m = getMonth(s.date);
    if (!m) return;
    if (!months[m]) months[m] = {oc:[],std:[],gmv_oc:0,gmv_std:0,loans:0};
    if (s.seg === 'one_click' || segs.oneClick.indexOf(s) >= 0) months[m].oc.push(s);
    else months[m].std.push(s);
  });

  // Enrich with BigQuery GMV data
  merchants.forEach(function(r) {
    var m = getMonth(r.first_loan_date);
    if (!m) return;
    if (!months[m]) months[m] = {oc:[],std:[],gmv_oc:0,gmv_std:0,loans:0};
    if (r.segment === 'one_click') months[m].gmv_oc += (r.total_gmv||0);
    else months[m].gmv_std += (r.total_gmv||0);
    months[m].loans += (r.total_loans||0);
  });

  var keys = Object.keys(months).sort().reverse(); // most recent first

  // Build tabs
  var tabsHtml = '<button class="mtab active" onclick="selectMonth(\'all\',this)">All time</button>';
  keys.forEach(function(k) {
    var total = months[k].oc.length + months[k].std.length;
    tabsHtml += '<button class="mtab" onclick="selectMonth(\'' + k + '\',this)">' + (MONTH_LABELS[k]||k) + ' (' + total + ')</button>';
  });
  document.getElementById('month-tabs').innerHTML = tabsHtml;

  window._MONTHS = months;
  window._MONTH_KEYS = keys;
  renderMonthView('all');
}

function selectMonth(key, btn) {
  ACTIVE_MONTH = key;
  document.querySelectorAll('.mtab').forEach(function(b){b.classList.remove('active');});
  btn.classList.add('active');
  renderMonthView(key);
  renderTable();
}

function renderMonthView(key) {
  var months = window._MONTHS || {};
  var keys   = window._MONTH_KEYS || [];
  var statsEl     = document.getElementById('month-stats');
  var merchantsEl = document.getElementById('month-merchants');

  if (key === 'all') {
    var tOC=0,tStd=0,tGmvOC=0,tGmvStd=0,tLoans=0;
    keys.forEach(function(k){
      tOC+=months[k].oc.length; tStd+=months[k].std.length;
      tGmvOC+=months[k].gmv_oc; tGmvStd+=months[k].gmv_std;
      tLoans+=months[k].loans;
    });
    statsEl.innerHTML =
      '<div class="mstat"><div class="msl">Total merchants</div><div class="msv">'+(tOC+tStd)+'</div><div class="mss">with activity</div></div>'+
      '<div class="mstat"><div class="msl"><i class="bi bi-lightning-charge-fill" style="color:var(--sea)"></i> One-Click GMV</div><div class="msv" style="color:var(--sea)">$'+Math.round(tGmvOC).toLocaleString('en-US')+'</div><div class="mss">'+tOC+' merchants</div></div>'+
      '<div class="mstat"><div class="msl"><i class="bi bi-person-check-fill" style="color:var(--teal)"></i> Standard GMV</div><div class="msv" style="color:var(--teal)">$'+Math.round(tGmvStd).toLocaleString('en-US')+'</div><div class="mss">'+tStd+' merchants</div></div>'+
      '<div class="mstat"><div class="msl">Total GMV</div><div class="msv">$'+Math.round(tGmvOC+tGmvStd).toLocaleString('en-US')+'</div><div class="mss">MXN · '+tLoans+' loans</div></div>';
    merchantsEl.innerHTML = '<div class="mm-title">Select a month to see GMV breakdown and merchant list</div>';
    return;
  }

  var m = months[key];
  if (!m) { statsEl.innerHTML=''; merchantsEl.innerHTML='<div style="padding:20px;color:var(--t3);font-size:13px;">No data</div>'; return; }
  var total = m.oc.length + m.std.length;
  var gmvTotal = m.gmv_oc + m.gmv_std;
  var pctOC  = gmvTotal > 0 ? Math.round((m.gmv_oc /gmvTotal)*100) : 0;
  var pctStd = gmvTotal > 0 ? Math.round((m.gmv_std/gmvTotal)*100) : 0;

  statsEl.innerHTML =
    '<div class="mstat"><div class="msl">Activated</div><div class="msv">'+total+'</div><div class="mss">'+(MONTH_LABELS[key]||key)+'</div></div>'+
    '<div class="mstat"><div class="msl"><i class="bi bi-lightning-charge-fill" style="color:var(--sea)"></i> One-Click GMV</div><div class="msv" style="color:var(--sea)">$'+Math.round(m.gmv_oc).toLocaleString('en-US')+'</div><div class="mss">'+m.oc.length+' merchants · '+pctOC+'% of month</div></div>'+
    '<div class="mstat"><div class="msl"><i class="bi bi-person-check-fill" style="color:var(--teal)"></i> Standard GMV</div><div class="msv" style="color:var(--teal)">$'+Math.round(m.gmv_std).toLocaleString('en-US')+'</div><div class="mss">'+m.std.length+' merchants · '+pctStd+'% of month</div></div>'+
    '<div class="mstat"><div class="msl">Total GMV</div><div class="msv">$'+Math.round(gmvTotal).toLocaleString('en-US')+'</div><div class="mss">MXN · '+m.loans+' loans</div></div>';

  // Mix bar
  var bar = '<div style="margin:0 0 14px;padding:10px 14px;background:var(--surf);border-radius:12px;">'
    + '<div style="font-size:10px;font-weight:800;color:var(--t3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px;">GMV mix</div>'
    + '<div style="display:flex;height:8px;border-radius:100px;overflow:hidden;gap:2px;">'
    + '<div style="width:'+pctOC+'%;background:var(--sea);border-radius:100px 0 0 100px;min-width:'+(m.gmv_oc>0?'4px':'0')+'"></div>'
    + '<div style="width:'+pctStd+'%;background:var(--teal);border-radius:0 100px 100px 0;min-width:'+(m.gmv_std>0?'4px':'0')+'"></div>'
    + '</div>'
    + '<div style="display:flex;gap:16px;margin-top:6px;font-size:11px;">'
    + '<span style="color:var(--sea);font-weight:600;"><i class="bi bi-lightning-charge-fill"></i> One-Click '+pctOC+'%</span>'
    + '<span style="color:var(--teal);font-weight:600;"><i class="bi bi-person-check-fill"></i> Standard '+pctStd+'%</span>'
    + '</div></div>';

  // Get merchant detail from DATA
  var monthMerchants = DATA.filter(function(r){ return getMonth(r.first_loan_date) === key; });
  var ocM   = monthMerchants.filter(function(r){return r.segment==='one_click';});
  var stdM  = monthMerchants.filter(function(r){return r.segment==='standard';});

  function chipList(arr) {
    return arr.map(function(r){
      var sc = r.segment==='one_click'?'mc-oc':'mc-std';
      var sl = r.segment==='one_click'?'⚡ One-Click':'✓ Standard';
      return '<div class="mm-chip"><div class="mc-name">'+r.merchant_name+'</div>'
        +'<div class="mc-id">#'+r.merchant_id+' · $'+Math.round(r.total_gmv||0).toLocaleString('en-US')+'</div>'
        +'<div class="mc-seg '+sc+'">'+sl+'</div></div>';
    }).join('');
  }

  var sections = '';
  if (ocM.length)  sections += '<div class="mm-title" style="color:var(--sea);margin-bottom:8px;"><i class="bi bi-lightning-charge-fill"></i> One-Click ('+ocM.length+')</div><div class="mm-grid" style="margin-bottom:16px;">'+chipList(ocM)+'</div>';
  if (stdM.length) sections += '<div class="mm-title" style="color:var(--teal);margin-bottom:8px;"><i class="bi bi-person-check-fill"></i> Standard ('+stdM.length+')</div><div class="mm-grid">'+chipList(stdM)+'</div>';
  if (!sections)   sections  = '<div style="font-size:12px;color:var(--t3);">No loan activity recorded for this month yet.</div>';

  merchantsEl.innerHTML = bar + sections;
}

// ============================================================
// TABLE
// ============================================================
function prio(r) {
  if (r.dq_rate_pct === null) return 'PENDING';
  if (r.gmv_at_risk >= 3000 || r.dq_rate_pct >= 50) return 'HIGH';
  if (r.gmv_at_risk >= 500  || r.dq_rate_pct >= 20) return 'MEDIUM';
  return 'LOW';
}

function getVerdict(r) {
  var p    = prio(r);
  var gmvS = mxn(r.total_gmv) + ' MXN';
  var arS  = r.gmv_at_risk != null ? mxn(r.gmv_at_risk) + ' MXN' : 'unknown';
  var dqS  = r.dq_rate_pct  != null ? r.dq_rate_pct + '%' : 'pending';
  var today = new Date('2026-05-19');
  var first = r.first_loan_date ? new Date(r.first_loan_date) : today;
  var da   = Math.round((today - first) / 86400000);
  var dl   = Math.max(0, 22 - da);

  if (p==='HIGH')    return {cls:'v-high', txt:'🚨 High priority — Of '+gmvS+' originated, '+arS+' is predicted delinquent ('+dqS+' DQ). '+(r.new_customer_ratio>=0.9&&r.total_loans>=2?'All loans went to first-time customers — consistent with collusion or synthetic identity. ':'')+'Recommend immediate review and payment freeze.'};
  if (p==='MEDIUM')  return {cls:'v-med',  txt:'⚡ Medium priority — '+arS+' at risk from '+dqS+' DQ on '+gmvS+'. '+(r.total_loans>=8&&r.unique_customers<=3?r.total_loans+' loans across only '+r.unique_customers+' customer(s) — loan concentration. ':'')+'Monitor over next 30 days.'};
  if (p==='PENDING') return {cls:'v-pending',txt:'⏳ DQ pending — '+gmvS+' originated, '+da+' day(s) active, DOB22 ready in ~'+dl+' day(s). '+(r.total_gmv>=20000?'Large exposure — flag for priority review when DQ matures. ':'')+(r.new_customer_ratio>=1.0&&r.total_loans>=2?'100% new customer ratio on '+r.total_loans+' loans worth watching. ':'')+(r.avg_ticket>=10000?'Avg ticket '+mxn(r.avg_ticket)+' MXN is high for a new merchant. ':'')+'Re-evaluate at day 22.'};
  return {cls:'v-low', txt:'✅ Clean — DQ '+dqS+' on '+gmvS+'. GMV at risk: $0. '+(r.total_loans>=8&&r.unique_customers<=3?'Note: '+r.total_loans+' loans to only '+r.unique_customers+' customers — monitor if volume grows. ':'')+'No fraud signals.'};
}

function mxn(n)  { return n == null ? '—' : '$' + Math.round(n).toLocaleString('en-US'); }
function dqFmt(n){ if(n==null) return '<span style="font-size:10px;color:var(--t3)">—&lt;22d</span>'; var c=n>=40?'var(--red)':n>=20?'var(--yellow)':'var(--green)'; return '<b style="color:'+c+'">'+n+'%</b>'; }
function barHTML(r){
  if(r.gmv_at_risk==null) return '<span style="font-size:10px;color:var(--t3)">pending</span>';
  if(r.gmv_at_risk===0)   return '<span style="font-size:11px;color:var(--green);font-weight:700;">$0 — clean</span>';
  var pct=Math.min(100,Math.round((r.gmv_at_risk/MAX_RISK)*100));
  var c=r.gmv_at_risk>=3000?'var(--red)':r.gmv_at_risk>=500?'var(--yellow)':'var(--orange)';
  return '<div class="bar-wrap"><div class="bar-bg"><div class="bar-fill" style="width:'+pct+'%;background:'+c+'"></div></div><span class="bar-val" style="color:'+c+'">'+mxn(r.gmv_at_risk)+'</span></div>';
}

function updateSortUI() {
  ['risk','gmv','dq','loans'].forEach(function(k){
    var btn=document.getElementById('btn-'+k), ico=document.getElementById('icon-'+k);
    var th=document.getElementById('th-'+k), thico=document.getElementById('th-icon-'+k);
    var active=SORT===k, dir=SORT_DIRS[k];
    var cls=active?(dir?'bi bi-sort-up':'bi bi-sort-down'):'bi bi-arrow-down-up';
    if(btn)btn.classList.toggle('active',active);
    if(ico)ico.className=cls;
    if(th)th.classList.toggle('sorted',active);
    if(thico){thico.className=cls;thico.style.opacity=active?'1':'0.4';}
  });
  var ni=document.getElementById('th-icon-name');
  if(ni){ni.className=(SORT==='name'?(SORT_DIRS.name?'bi bi-sort-up':'bi bi-sort-down'):'bi bi-arrow-down-up');ni.style.opacity=SORT==='name'?'1':'0.4';}
}

function setSort(key,btn) {
  if(SORT===key) SORT_DIRS[key]=!SORT_DIRS[key]; else SORT=key;
  updateSortUI(); renderTable();
}

function toggle(id) { EXP[id]=!EXP[id]; renderTable(); }

function renderTable() {
  var q    = (document.getElementById('q').value||'').toLowerCase().trim();
  var seg  = document.getElementById('f-seg').value;
  var show = document.getElementById('f-show').value;

  var list = DATA.filter(function(r) {
    if (q && !(r.merchant_name.toLowerCase().includes(q) || r.merchant_id.includes(q))) return false;
    if (seg  !== 'all' && r.segment !== seg) return false;
    if (show === 'risk'    && !(r.dq_rate_pct != null && r.gmv_at_risk > 0)) return false;
    if (show === 'pending' && r.dq_rate_pct != null) return false;
    if (ACTIVE_MONTH !== 'all' && getMonth(r.first_loan_date) !== ACTIVE_MONTH) return false;
    return true;
  });

  var asc = SORT_DIRS[SORT];
  list.sort(function(a,b) {
    if (SORT==='name') { var av=a.merchant_name.toLowerCase(),bv=b.merchant_name.toLowerCase(); return asc?(av>bv?1:-1):(av<bv?1:-1); }
    var av,bv;
    if      (SORT==='gmv')   { av=a.total_gmv;    bv=b.total_gmv; }
    else if (SORT==='dq')    { av=a.dq_rate_pct==null?-1:a.dq_rate_pct; bv=b.dq_rate_pct==null?-1:b.dq_rate_pct; }
    else if (SORT==='loans') { av=a.total_loans;  bv=b.total_loans; }
    else                     { av=a.gmv_at_risk==null?-1:a.gmv_at_risk; bv=b.gmv_at_risk==null?-1:b.gmv_at_risk; }
    return asc?av-bv:bv-av;
  });

  document.getElementById('fcount').textContent = list.length + ' merchants';

  var html = '';
  list.forEach(function(r) {
    var p=prio(r), pb='r-'+p, pl=p==='PENDING'?'⏳ Pending':p==='HIGH'?'🚨 High':p==='MEDIUM'?'⚡ Medium':'✅ Clean';
    var sc=r.segment==='one_click'?'seg-oc':'seg-std', sl=r.segment==='one_click'?'One-Click':'Standard';
    var exp=EXP[r.merchant_id], v=getVerdict(r);
    html += '<tr class="dr'+(p==='HIGH'?' hi':'')+'" onclick="toggle(\''+r.merchant_id+'\')">';
    html += '<td><div class="mname">'+r.merchant_name+' <i class="bi bi-chevron-'+(exp?'up':'down')+'" style="font-size:10px;color:var(--t3);"></i></div><div class="mid">#'+r.merchant_id+'</div></td>';
    html += '<td><span class="'+sc+'">'+sl+'</span></td>';
    html += '<td><b>'+mxn(r.total_gmv)+'</b></td>';
    html += '<td>'+dqFmt(r.dq_rate_pct)+'</td>';
    html += '<td>'+barHTML(r)+'</td>';
    html += '<td>'+r.total_loans+'</td>';
    html += '<td>'+r.unique_customers+'</td>';
    html += '<td>'+mxn(r.avg_ticket)+'</td>';
    html += '<td>'+Math.round((r.new_customer_ratio||0)*100)+'%</td>';
    html += '<td><span class="rbadge '+pb+'">'+pl+'</span></td>';
    html += '</tr>';
    if (exp) {
      html += '<tr class="xrow"><td colspan="10"><div class="xinner">';
      html += '<div class="xtitle"><i class="bi bi-shield-exclamation"></i> Fraud analysis — '+r.merchant_name+' (#'+r.merchant_id+')</div>';
      html += '<div class="xgrid">';
      html += '<div class="xstat"><div class="xl">Total GMV</div><div class="xv">'+mxn(r.total_gmv)+' MXN</div></div>';
      html += '<div class="xstat"><div class="xl">DQ rate DOB22</div><div class="xv '+(r.dq_rate_pct>=30?'danger':r.dq_rate_pct>=20?'warn':'')+'"> '+(r.dq_rate_pct!=null?r.dq_rate_pct+'%':'Pending — &lt;22 days')+'</div></div>';
      html += '<div class="xstat"><div class="xl">GMV at risk</div><div class="xv '+(r.gmv_at_risk>=3000?'danger':r.gmv_at_risk>=500?'warn':'')+'"> '+(r.gmv_at_risk!=null?mxn(r.gmv_at_risk)+' MXN':'Pending')+'</div></div>';
      html += '<div class="xstat"><div class="xl">Loans / customers</div><div class="xv">'+r.total_loans+' / '+r.unique_customers+'</div></div>';
      html += '<div class="xstat"><div class="xl">Avg ticket</div><div class="xv '+(r.avg_ticket>=10000?'warn':'')+'">'+mxn(r.avg_ticket)+' MXN</div></div>';
      html += '<div class="xstat"><div class="xl">% new customers</div><div class="xv '+(r.new_customer_ratio>=0.9&&r.total_loans>=2?'danger':r.new_customer_ratio>=0.7?'warn':'')+'"> '+Math.round((r.new_customer_ratio||0)*100)+'%</div></div>';
      html += '<div class="xstat"><div class="xl">First loan</div><div class="xv" style="font-size:12px;">'+(r.first_loan_date||'—')+'</div></div>';
      html += '<div class="xstat"><div class="xl">Last loan</div><div class="xv" style="font-size:12px;">'+(r.last_loan_date||'—')+'</div></div>';
      html += '</div>';
      html += '<div class="verdict '+v.cls+'">'+v.txt+'</div>';
      html += '</div></td></tr>';
    }
  });

  document.getElementById('tbody').innerHTML = html || '<tr><td colspan="10" style="padding:32px;text-align:center;color:var(--t3);">No merchants match this filter</td></tr>';
}

